	<ItemGroup>
		<ProjectReference Include="..\DevGuardAI.BLL\DevGuardAI.BLL.csproj" />
		<ProjectReference Include="..\DevGuardAI.Shared\DevGuardAI.Shared.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.13" />
	  <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.0">
