# =====================================================
# DevGuardAI — Environment Variables Template
# =====================================================
# Hướng dẫn:
#   1. Copy file này: cp .env.example .env
#   2. Điền giá trị thật vào file .env
#   3. KHÔNG commit file .env lên git
# =====================================================

# ----------------------
# Database (SQL Server)
# ----------------------
# Yêu cầu: ít nhất 8 ký tự, có chữ hoa, chữ thường, số, ký tự đặc biệt
DB_PASSWORD=

# ----------------------
# JWT
# ----------------------
# Secret key để ký JWT token — khuyến nghị 32+ ký tự
JWT_KEY=

# Issuer và Audience phải khớp với appsettings.json
JWT_ISSUER=DevGuardAI
JWT_AUDIENCE=DevGuardAIUsers
JWT_EXPIRE_MINUTES=60

# ----------------------
# Gemini AI
# ----------------------
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
